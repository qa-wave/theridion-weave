# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-32-byte-hex-string

# Database (Neon Postgres -- add via Vercel Marketplace, then run `vercel env pull`)
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Weave ingest token for accepting run results from Eyes/Net/Runner
# WEAVE_INGEST_TOKEN=

# Public app URL
# NEXT_PUBLIC_APP_URL=https://theridion-weave.qawave.ai

# Dev overrides
# NEXT_PUBLIC_AUTH_DISABLED=0
